# Copy to .env and adjust as needed.

# ──────── Simulation ────────
PX4_SIM_MODEL=gazebo-classic_iris
PX4_GZ_WORLD=search_area

# ──────── Perception ────────
# Model precision: bf16 | fp16 | int8
# This is the knob that drives the BF16-vs-FP16 competitive analysis.
MODEL_PRECISION=bf16
MODEL_NAME=edgetam       # edgetam | sam2 | yolov8

# ──────── Comms ────────
# Link profile drives latency/jitter/loss applied by netem.
LINK_PROFILE=wifi_suburban    # wifi_suburban | 5g_lte | degraded
ENCODE_BITRATE_KBPS=6000
ENCODE_CODEC=h265             # h264 | h265 | av1

# ──────── Misc ────────
RUN_NAME=                     # Optional human label for the run directory
